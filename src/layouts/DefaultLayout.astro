---
import seo from "@/data/seo.json"
import { AstroFont } from "astro-font"
import "@/styles/global.css"
import Footer from "@/sections/Footer.astro"

import { getContent } from "@/utils/graphql-client"
import { faqQuery, aboutQuery } from "@/utils/queries"
import PageNavigation from "@/features/page-navigation/PageNavigation.astro"
import PageFaq from "@/features/page-faq/PageFaq.astro"
import PageSection from "@/shared/components/PageSection.astro"
import { ICONS, SECTION_IDS } from "@/shared/lib/constants.ts"
import Separator from "@/shared/components/Separator.astro"
const { faq } = await getContent(faqQuery)
const { aboutMe } = await getContent(aboutQuery)
const { schema: aboutSchema } = aboutMe
const { jsonLd: faqJsonLd } = faq
---

<html lang={seo.language} data-theme="light">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content={seo.additionalMeta.viewport} />
        <title>{seo.title}</title>
        <meta name="description" content={seo.description} />
        <meta name="author" content={seo.author} />
        <meta name="keywords" content={seo.keywords} />
        <meta name="robots" content={seo.robots} />
        <meta name="language" content={seo.language} />
        <meta name="format-detection" content={seo.additionalMeta.formatDetection} />
        <meta name="referrer" content={seo.additionalMeta.referrer} />
        <meta name="color-scheme" content={seo.additionalMeta.colorScheme} />
        <meta name="supported-color-schemes" content={seo.additionalMeta.supportedColorSchemes} />

        <!-- Canonical and Sitemap -->
        <link rel="canonical" href={seo.siteUrl} />
        <link rel="sitemap" href="/sitemap-index.xml" />

        <!-- Preconnect for external domains -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://eu-west-2.graphassets.com" />

        <!-- DNS Prefetch as fallback -->
        <link rel="dns-prefetch" href="//fonts.googleapis.com" />
        <link rel="dns-prefetch" href="//fonts.gstatic.com" />
        <link rel="dns-prefetch" href="//eu-west-2.graphassets.com" />

        <!-- Standard favicon -->
        <link rel="icon" href="/favicon.ico" type="image/x-icon" />

        <!-- PNG favicons -->
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />

        <!-- Apple Touch Icon (for iOS bookmarks) -->
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />

        <!-- Web App Manifest (if you're pretending your site is an app) -->
        <link rel="manifest" href="/site.webmanifest" />

        <meta name="theme-color" content={seo.themeColor} />
        <meta name="msapplication-TileColor" content={seo.themeColor} />

        <!-- Enhanced Person Schema -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

        <!-- FAQ Schema -->
        <!--<script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />-->
        <script is:inline type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [
                    {
                        "@type": "Question",
                        "name": "What is your primary technical focus?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I am a frontend-focused Full Stack Developer specializing in building high-performance web applications using TypeScript, Next.js, and Astro, supported by scalable backend solutions like PostgreSQL, Supabase, and Cloudflare Workers."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How do you approach performance and SEO?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I treat performance as a core feature. By optimizing Core Web Vitals and implementing technical SEO improvements, I previously drove a 37% increase in organic traffic and reduced deployment turnaround times by 45% using Astro and Payload CMS."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How does your Android development journey add value to your web expertise?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I am expanding into Native Android Development to bridge the gap between web and mobile ecosystems. This allows me to apply my expertise in UI/UX and state management to mobile platforms, ensuring a seamless user experience across all devices."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "What is your experience with E-commerce and CMS architecture?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I have extensive experience with Shopify (Liquid), WordPress, and Headless CMS (Payload). I notably engineered a caching strategy for Google APIs that reduced external service costs by 43% while maintaining real-time inventory sync."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How do you handle data telemetry and analytics?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "I build with a data-driven mindset, having overhauled data telemetry using GA4 and GTM data layers. This increased marketing attribution accuracy by 92% for previous employers, enabling more precise business decision-making."
                        }
                    }
                ]
            }
        </script>

        <!-- Website Schema -->
        <script is:inline type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@graph": [
                    {
                        "@type": "WebSite",
                        "@id": "https://ericmaina.me/#website",
                        "url": "https://ericmaina.me",
                        "name": "Eric Maina Gathoni | Full Stack Developer",
                        "description": "Portfolio of Eric Maina Gathoni, a Full Stack Developer specializing in Next.js, Astro, and scalable backend architectures.",
                        "publisher": {
                            "@id": "https://ericmaina.me/about"
                        },
                        "inLanguage": "en"
                    },
                    {
                        "@type": "Person",
                        "@id": "https://ericmaina.me/#person",
                        "name": "Eric Maina Gathoni",
                        "url": "https://ericmaina.me/about",
                        "jobTitle": "Full Stack Developer",
                        "mainEntityOfPage": "https://ericmaina.me",
                        "address": {
                            "@type": "PostalAddress",
                            "addressLocality": "Nairobi",
                            "addressCountry": "Kenya"
                        },
                        "email": "ericmaina.gathoni@gmail.com",
                        "image": "https://ericmaina.me/images/og-image.png",
                        "description": "Full Stack Developer with 3+ years of experience building high-performance applications. Expert in React, Next.js, Astro, and serverless infrastructure.",
                        "sameAs": ["https://linkedin.com/in/exuseric", "https://github.com/exuseric"],
                        "knowsAbout": [
                            "Full Stack Development",
                            "Technical SEO",
                            "Next.js",
                            "Astro",
                            "TypeScript",
                            "PostgreSQL",
                            "Supabase",
                            "Cloudflare Workers",
                            "Payload CMS",
                            "Shopify Development",
                            "Web Performance Optimization",
                            "Infrastructure Optimization"
                        ],
                        "alumniOf": {
                            "@type": "EducationalOrganization",
                            "name": "Kenya Christian Industrial Training Institute",
                            "url": "https://kciti.edu/"
                        },
                        "hasCredential": [
                            {
                                "@type": "EducationalOccupationalCredential",
                                "name": "Diploma in Information Communication Technology",
                                "credentialCategory": "Diploma"
                            }
                        ],
                        "worksFor": [
                            {
                                "@type": "Organization",
                                "name": "Yellow Pages Kenya"
                            },
                            {
                                "@type": "Organization",
                                "name": "Optica Limited"
                            }
                        ]
                    }
                ]
            }
        </script>

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content={seo.openGraph.type} />
        <meta property="og:url" content={seo.openGraph.url} />
        <meta property="og:title" content={seo.openGraph.title} />
        <meta property="og:description" content={seo.openGraph.description} />
        <meta property="og:image" content={seo.openGraph.image.url} />
        <meta property="og:image:width" content={seo.openGraph.image.width} />
        <meta property="og:image:height" content={seo.openGraph.image.height} />
        <meta property="og:image:alt" content={seo.openGraph.image.alt} />
        <meta property="og:locale" content={seo.openGraph.locale} />
        <meta property="og:site_name" content={seo.openGraph.siteName} />

        <!-- Twitter -->
        <meta name="twitter:card" content={seo.twitter.card} />
        <meta name="twitter:site" content={seo.twitter.site} />
        <meta name="twitter:creator" content={seo.twitter.creator} />
        <meta name="twitter:title" content={seo.twitter.title} />
        <meta name="twitter:description" content={seo.twitter.description} />
        <meta name="twitter:image" content={seo.twitter.image} />

        <!-- Fonts with performance optimization -->
        <AstroFont
            config={[
                {
                    src: [],
                    name: "Google Sans Flex",
                    preload: true,
                    display: "swap",
                    selector: "body",
                    fallback: "sans-serif",
                    cssVariable: "font-family-sans",
                    googleFontsURL:
                        "https://fonts.googleapis.com/css2?family=Google+Sans+Flex:opsz,wght@6..144,1..1000&display=swap",
                },
            ]}
        />
    </head>

    <body class="bg-swirl text-on-surface">
        <a href="#main-content" class="skip-link">Skip to content</a>
        <PageNavigation />
        <main id="main-content" class="page-wrapper" tabindex="-1">
            <slot />
            <Separator />
            <PageSection title="Some Q&A" icon={ICONS.faq} id={SECTION_IDS.faq}>
                <PageFaq />
            </PageSection>
        </main>
        <Separator />
        <Footer />
        <Separator />
    </body>
</html>