---
import { cn } from "@/utils/cn"
import type { HTMLAttributes } from "astro/types"

export interface Props extends HTMLAttributes<"textarea"> {
    placeholder?: string
    disabled?: boolean
    required?: boolean
    invalid?: boolean
    name?: string
    id?: string
    rows?: number
    value?: string
}

const {
    placeholder,
    disabled = false,
    required = false,
    invalid = false,
    name,
    id,
    rows = 4,
    value,
    class: className,
    ...props
} = Astro.props

const classes = cn(
    "block w-full min-h-24 px-4 py-2 text-sm leading-tight align-middle",
    "bg-surface border border-scrim/20 rounded-md supports-[corner-shape:squircle]:rounded-xl squircle",
    "placeholder:text-muted-foreground",
    "transition duration-300 ease-transition-in-out",
    "focus:z-10 focus:border-primary focus:ring focus:ring-primary/5 focus:outline-none",
    "file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-on-surface",
    "disabled:cursor-not-allowed disabled:opacity-50",
    "invalid:ring-error",
    className,
)
---

<textarea
    class={classes}
    placeholder={placeholder}
    disabled={disabled}
    required={required}
    aria-invalid={invalid ? "true" : undefined}
    name={name}
    id={id}
    rows={rows}
    {...props}>{value}</textarea
>