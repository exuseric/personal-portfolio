---
import Input from "@/features/contact-form/components/Input.astro"
import Textarea from "@/features/contact-form/components/Textarea.astro"
import FormMessage from "@/features/contact-form/components/FormMessage.astro"
import { actions } from "astro:actions"
import { FORM_MESSAGES } from "@/shared/lib/constants.ts"
---

<form id="contact-form" class="max-w-prose w-full flex-col-start gap-y-4">
    <div id="form-messages">
        <FormMessage data-form-message="success" type="success" message={FORM_MESSAGES.success} class="hidden mb-4" />
        <FormMessage data-form-message="error" type="error" message={FORM_MESSAGES.incomplete} class="hidden mb-4" />
        <FormMessage data-form-message="server-error" type="error" message={FORM_MESSAGES.serverError} class="hidden mb-4" />
    </div>
    
    <div class="form-group">
        <label for="name">Name</label>
        <Input type="text" placeholder="Enter your name" name="name" id="name" required minlength="2" />
        <FormMessage data-field-error="name" message="" class="hidden mt-1" />
    </div>
    
    <div class="form-group">
        <label for="email">Email</label>
        <Input type="email" placeholder="Enter your email" name="email" id="email" required />
        <FormMessage data-field-error="email" message="" class="hidden mt-1" />
    </div>
    
    <div class="form-group">
        <label for="message">Message</label>
        <Textarea placeholder="Write your message" name="message" id="message" minlength="10" required />
        <FormMessage data-field-error="message" message="" class="hidden mt-1" />
    </div>
    
    <div class="form-group">
        <button type="submit" class="btn-filled">Send Message</button>
    </div>
</form>

<style>
    /* Data attribute based toggling */
    [data-visible="false"] {
        display: none;
    }
    
    [data-visible="true"] {
        display: block;
    }
    
    /* Fallback for the 'hidden' class if used initially */
    .hidden:not([data-visible="true"]) {
        display: none;
    }
</style>

<script>
    import { actions, isInputError } from 'astro:actions';

    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    // Message elements
    const successMsg = form?.querySelector('[data-form-message="success"]') as HTMLElement;
    const genericErrorMsg = form?.querySelector('[data-form-message="error"]') as HTMLElement;
    const serverErrorMsg = form?.querySelector('[data-form-message="server-error"]') as HTMLElement;
    const allMessages = form?.querySelectorAll('[data-form-message], [data-field-error]') as NodeListOf<HTMLElement>;

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (!submitButton) return;

        // Reset all messages
        allMessages.forEach(el => {
            el.setAttribute('data-visible', 'false');
            el.classList.add('hidden'); // Ensure hidden class is also present
        });

        submitButton.disabled = true;
        const originalButtonText = submitButton.innerText;
        submitButton.innerText = 'Sending...';

        const formData = new FormData(form);
        const { data, error } = await actions.contact.sendMessage(formData);

        submitButton.disabled = false;
        submitButton.innerText = originalButtonText;

        if (data) {
            // Success
            if (successMsg) {
                successMsg.setAttribute('data-visible', 'true');
                successMsg.classList.remove('hidden');
                successMsg.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
            form.reset();
        } else if (error) {
            if (isInputError(error)) {
                // Field-specific errors
                Object.entries(error.fields).forEach(([field, messages]) => {
                    const errorEl = form.querySelector(`[data-field-error="${field}"]`) as HTMLElement;
                    if (errorEl && messages) {
                        errorEl.innerText = messages.join(', ');
                        errorEl.setAttribute('data-visible', 'true');
                        errorEl.classList.remove('hidden');
                    }
                });
                // Generic "incomplete" message
                if (genericErrorMsg) {
                    genericErrorMsg.setAttribute('data-visible', 'true');
                    genericErrorMsg.classList.remove('hidden');
                }
            } else {
                // General server error
                if (serverErrorMsg) {
                    serverErrorMsg.setAttribute('data-visible', 'true');
                    serverErrorMsg.classList.remove('hidden');
                }
            }
        }
    });
</script>
