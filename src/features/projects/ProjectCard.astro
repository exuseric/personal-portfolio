---
import Badge from "@/shared/components/badge/Badge.astro"
import Icon from "@/shared/components/Icon.astro"
import { ICONS } from "@/shared/lib/constants.ts"
import type { Project } from "@/shared/lib/types"
interface Props {
    project: Project
}
const { project } = Astro.props
---

<article
    class="h-full border border-on-surface/20 squircle rounded-3xl supports-[corner-shape:squircle]:rounded-4xl p-4 flex-col-start gap-y-4 glass hover:shadow-level-1 transition-shadow ease-transition-in-out hover:bg-surface-container-high"
>
    <header class="flex-row-between items-center flex-wrap gap-y-2">
        <h3 class="flex-col-start gap-y-2 mb-0!">
            <Badge class="w-fit"> {project.status} </Badge>
            {project.title}
        </h3>
        <div class="flex-row-start gap-x-2">
            {
                project.githubLink && (
                    <a
                        class="btn-text"
                        href={project.githubLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`View ${project.title} source code on GitHub (opens in a new tab)`}
                    >
                        Github
                        <Icon name={ICONS.github} class="size-5" />
                    </a>
                )
            }
            {
                project.demoLink && (
                    <a
                        class="btn-filled"
                        href={project.demoLink}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`Visit ${project.title} live demo (opens in a new tab)`}
                    >
                        Visit
                        <Icon name={ICONS.link} class="size-5" />
                    </a>
                )
            }
        </div>
    </header>
    <p>
        {project.description}
    </p>

    <ul aria-label="tech stack" class="flex-row-start flex-wrap gap-x-2 items-center">
        <li>
            <Icon name={ICONS.tag} class="size-5 text-tertiary" />
        </li>
        {
            project.techStack.map((stack) => (
                <li>
                    <Badge variant="tertiary">{stack}</Badge>
                </li>
            ))
        }
    </ul>
</article>