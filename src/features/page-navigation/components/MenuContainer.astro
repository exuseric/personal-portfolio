---
import { links } from "@/features/page-navigation/lib/get-menu-links.ts"
import Icon from "@/shared/components/Icon.astro"
---

<nav class="flex-row-center md:flex-row-end gap-x-2 w-full" data-page-menu>
    {
        links.map((link) => (
            <a
                href={link.url}
                class="btn-text flex-col-center md:flex-row-center py-2 px-4 data-active:text-on-primary data-active:bg-primary"
            >
                <Icon name={link.icon} class="size-5" />
                {link.label}
            </a>
        ))
    }
</nav>

<script>
    const pageMenu = document.querySelectorAll("nav[data-page-menu]")

    function setHash(hash: string) {
        if (!pageMenu.length) throw new Error("Page Navigation Menu Not Found")
        pageMenu.forEach((menu) => {
            const links = menu.querySelectorAll("a")
            links.forEach((link) => {
                link.removeAttribute("data-active")
                link.removeAttribute("aria-current")

                if (link.getAttribute("href") === hash || (hash === "" && link.getAttribute("href") === "/")) {
                    link.setAttribute("data-active", "")
                    link.setAttribute("aria-current", "page")
                }
            })
        })
    }
    const updateHash = () => setHash(window.location.hash || "/")
    updateHash()
    window.addEventListener("hashchange", updateHash)
</script>
