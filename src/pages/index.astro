---
import DefaultLayout from "@/layouts/DefaultLayout.astro"
import Projects from "@/features/projects/ProjectContainer.astro"
import Hero from "@/features/page-hero/Hero.astro"
import Separator from "@/shared/components/Separator.astro"
import PageSection from "@/shared/components/PageSection.astro"
import { ICONS, SECTION_IDS } from "@/shared/lib/constants.ts"
import ContactForm from "@/features/contact-form/ContactForm.astro"
---

<DefaultLayout>
    <Hero />
    <Separator />
    <Projects />
    <Separator />
    <PageSection icon={ICONS.contact} id={SECTION_IDS.contact} title="Let's Connect">
        <ContactForm />
    </PageSection>
</DefaultLayout>
