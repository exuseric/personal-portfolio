---
import { getContent } from "@/utils/graphql-client"
import { contactQuery } from "@/utils/queries"
import Form from "@/components/contact/Form.astro"
import { Icon } from "astro-icon/components"
import About from "@/sections/About.astro"
import SocialLinks from "@/shared/components/social-links/SocialLinks.astro"
import { ICONS } from "@/shared/lib/constants.ts"
---

<div class="grid grid-rows-[auto] md:grid-cols-2 md:grid-rows-1 gap-x-0 md:gap-y-0 md:items-start py-8">
    <article class="bg-surface-brand-subtle px-1 py-12 layout-grid md:p-12 w-full h-full squircle rounded-[6em]">
        <div class="my-12">
            <About />
        </div>
    </article>
    <div class="layout-grid md:p-12 flex flex-col items-center justify-center">
        <SocialLinks />
        <div class="my-12 w-full">
            <Form />
        </div>
    </div>
</div>