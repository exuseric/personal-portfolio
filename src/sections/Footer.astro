---
import { ICONS, SOCIAL_LINKS } from "@/shared/lib/constants"
import Icon from "@/shared/components/Icon.astro"

const footerLinks = [
    {
        name: "github",
        url: SOCIAL_LINKS.github,
        icon: ICONS.github,
        title: "connect on github",
    },
    {
        name: "behance",
        url: SOCIAL_LINKS.behance,
        icon: ICONS.behance,
        title: "connect on behance",
    },
    {
        name: "linkedin",
        url: SOCIAL_LINKS.linkedin,
        icon: ICONS.linkedin,
        title: "connect on linkedin",
    },
    {
        name: "mail",
        url: "mailto:hello@ericmaina.me",
        icon: ICONS.contact,
        title: "hello@ericmaina.me",
    },
]

const email = footerLinks.find((link) => link.name === "mail")
---

<footer class="layout-grid">
    <div class="bg-primary breakout layout-grid py-16 text-on-primary rounded-xl">
        <nav class="flex flex-col md:flex-row flex-wrap items-start justify-start md:justify-between gap-y-8 w-full" aria-label="Footer social links">
            {
                footerLinks.map((link) => (
                    <a
                        class="btn-filled-tonal text-xl w-full md:w-fit"
                        href={link.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={`${link.title} (opens in a new tab)`}
                    >
                        <span>{link.name.toUpperCase()}</span>
                        <Icon name={link.icon} class="size-5 text-current" />
                    </a>
                ))
            }
        </nav>
        <div class="flex-row-between flex-wrap items-center gap-4">
            <p class="copyright text-sm">
                &copy;&nbsp;{new Date().getFullYear()}&nbsp;Eric Gathoni. All rights reserved. Nairobi, Kenya
            </p>
            <a class="btn-text text-current" href={email?.url} target="_blank" rel="noopener noreferrer" aria-label="Send an email to Eric (opens in a new tab)">{email?.title}</a>
        </div>
    </div>
</footer>
